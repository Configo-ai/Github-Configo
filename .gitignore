# Ignore sub-repos (cloned by setup script)
Configo-Backend/
Configo-AI-Worker/
Configo-Frontend/
Configo-Web-Frontend/
Configo-Developer-Frontend/
Configo-Deployment/
bones/

# Ignore other generated files
.claude/settings.local.json
__pycache__/
*.pyc

.worktrees/

# Sessions are kept locally only — workspace_conversation_id correlation
# between Claude Code / OpenCode still works, but conversation bodies and
# metadata are not committed (false-positive retrieval risk + privacy).
sessions/
.sessions-archive/

# Generated at setup time from manifest.system_prompt_appends.
tools/.system_prompt_append.md

# Trace log for the code-graph router (only written when CONFIGO_CGRAG_TRACE=1).
tools/.code_graph_router.log

# Per-tool compacted descriptions cache (regenerated when an upstream tool
# description changes; not a build artifact worth committing).
tools/.mcp_descriptions.json
tools/.mcp_compactor.log
